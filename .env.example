# AgenticConverter - Environment Configuration
# Copy this file to .env and fill in your values.
# These override config.json defaults. CLI arguments override both.

# Global Application Overrides (all optional)
# MAX_ITERATIONS=5
# OUTPUT_DIR=.data/output
# VERBOSE=false

# LLM Server Connection
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=qwen2.5-coder-14b-instruct

# Converter LLM Parameters
# LLM_CONVERTER_TEMPERATURE=0.35
# LLM_CONVERTER_MAX_TOKENS=4096
# LLM_CONVERTER_TOP_P=0.95
# LLM_CONVERTER_TOP_K=40

# Reviewer LLM Parameters
# LLM_REVIEWER_TEMPERATURE=0.1
# LLM_REVIEWER_MAX_TOKENS=4096
# LLM_REVIEWER_TOP_P=0.9
# LLM_REVIEWER_TOP_K=20
