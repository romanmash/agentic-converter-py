# --------------------------------------------------
# OS / editor noise
# --------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# --------------------------------------------------
# Local environment and secrets (never commit)
# --------------------------------------------------
.env
.env.local
.env.*.local
!.env.example
config/config.local.json

# --------------------------------------------------
# Python
# --------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.venv/
venv/
.envrc
.mypy_cache/
.pytest_cache/
.ruff_cache/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/
__pypackages__/

# --------------------------------------------------
# uv
# --------------------------------------------------
.uv-cache/
.uv-python/

# --------------------------------------------------
# Runtime and temporary project data
# --------------------------------------------------
# Keep only folder placeholders in version control:
#   .data/input/.gitkeep
#   .data/output/.gitkeep
.data/**
!.data/input/
!.data/input/.gitkeep
!.data/output/
!.data/output/.gitkeep
.tmp/
.cache/
coverage/
logs/
*.log

# --------------------------------------------------
# IDE / AI tooling local settings
# --------------------------------------------------
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
